# ============================================================
# Docker Environment Variables (TEMPLATE)
# ============================================================
# Copy this file to .env at the project root and fill in values.
# This file is used by docker-compose.yml
# NEVER commit the real .env to version control.
# ============================================================

# --- Django ---
SECRET_KEY=your-strong-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=*

# --- PostgreSQL ---
DB_NAME=conference_db
DB_USER=postgres
DB_PASSWORD=change-me-to-a-strong-password

# --- CORS ---
CORS_ALLOW_ALL_ORIGINS=True

# --- Email ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=MoA Conference Center <your-email@gmail.com>

# --- Frontend API Base ---
# In Docker, Nginx proxies /api/ to the backend container,
# so the frontend just uses "/api" (relative path).
VITE_API_BASE=/api
